rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------- HELPER FUNCTIONS ----------
    function isLoggedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isLoggedIn() && (
        request.auth.token.email == 'mujeeb@admin.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isOwner(data) {
      return isLoggedIn() && (
        (data.studentEmail != null && data.studentEmail == request.auth.token.email) ||
        (data.studentId != null && data.studentId == request.auth.uid) ||
        (data.email != null && data.email == request.auth.token.email)
      );
    }

    // ---------- USERS & STUDENTS ----------
    match /users/{userId} {
      allow read, write: if isLoggedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /students/{docId} {
      allow read: if isAdmin() || isOwner(resource.data) || request.auth.uid == docId;
      allow write: if isAdmin();
    }

    // ---------- ACADEMICS ----------
    match /subjects/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
    match /lessons/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ---------- COLLECTIONS WITH STUDENT FILTERING ----------
    
    // Helper for shared student collections
    match /studentAssignments/{docId} {
      allow read: if isAdmin() || isOwner(resource.data);
      allow write: if isAdmin();
    }

    match /submissions/{docId} {
      allow read: if isAdmin() || isOwner(resource.data);
      allow create: if isLoggedIn() && (request.resource.data.studentEmail == request.auth.token.email || request.resource.data.studentId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /enrollments/{docId} {
      allow read: if isAdmin() || isOwner(resource.data);
      allow write: if isAdmin();
    }

    match /attendance/{docId} {
      allow read: if isAdmin() || isOwner(resource.data);
      allow write: if isAdmin();
    }

    match /grades/{docId} {
      allow read: if isAdmin() || isOwner(resource.data);
      allow write: if isAdmin();
    }

    match /contacts/{docId} {
      allow create: if true; 
      allow read: if isAdmin(); 
      allow write: if isAdmin();
    }
  }
}
